{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["esnext", "dom"],
    "baseUrl": ".",
    "module": "esnext",
    "moduleResolution": "node",
    "paths": {
      "@/*": ["apps/web/src/*"],
      "@components/*": ["apps/web/src/components/*"]
    },
    "resolveJsonModule": true,
    "types": ["vite/client", "node", "element-plus/global"],
    "allowJs": true,
    "strict": false,
    "sourceMap": true,
    "esModuleInterop": true
  },
  "include": ["docs/**/*.ts", "docs/**/*.d.ts", "docs/**/*.vue", "docs/vite.config.ts", "docs/.vitepress/config.mts"],
  "exclude": ["node_modules", "apps/*/dist", "docs/.vitepress/dist"]
}
