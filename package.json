{
  "name": "@sugarat/easypicker2",
  "version": "2.7.3",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @sugarat/easypicker2-web dev",
    "dev:test": "pnpm --filter @sugarat/easypicker2-web dev:test",
    "web:dev": "pnpm --filter @sugarat/easypicker2-web dev",
    "web:build": "pnpm --filter @sugarat/easypicker2-web build",
    "build": "pnpm --filter @sugarat/easypicker2-web build",
    "build:test": "pnpm --filter @sugarat/easypicker2-web build:test",
    "serve": "pnpm --filter @sugarat/easypicker2-web serve",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:serve": "vitepress serve docs",
    "docs:deploy": "zx scripts/deploy/docs.mjs",
    "deploy:prod": "zx scripts/deploy/prod.mjs",
    "deploy:test": "zx scripts/deploy/test.mjs",
    "upload:oss": "pnpm --filter @sugarat/easypicker2-web upload:oss",
    "update:version": "pnpm --filter @sugarat/easypicker2-web update:version",
    "preinstall": "npm config set registry https://registry.npmmirror.com/",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^1.1.4",
    "@sugarat/theme": "^0.5.19",
    "@vueuse/core": "^14.3.0",
    "axios": "^0.31.1",
    "element-plus": "2.13.7",
    "vitepress": "2.0.0-alpha.17",
    "vitepress-plugin-51la": "^0.1.0",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@types/node": "20",
    "eslint": "^10.2.1",
    "eslint-plugin-format": "^2.0.1",
    "lint-staged": "^15.2.7",
    "pagefind": "^1.5.2",
    "sass": "^1.99.0",
    "simple-git-hooks": "^2.11.1",
    "typescript": "^5",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.10"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix --no-warn-ignored"
  }
}
